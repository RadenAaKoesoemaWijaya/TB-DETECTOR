# TB DETECTOR - Git Ignore File
# https://git-scm.com/docs/gitignore

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
ENV/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# PyCharm / VSCode
.idea/
.vscode/
*.swp
*.swo
*~

# Environment variables
.env
.env.local
.env.*.local

# Model weights (large files)
app/models/weights/*.pth
app/models/weights/*.pt
app/models/weights/*.onnx
app/models/weights/*.h5

# Dataset files (large)
data/uploaded_dataset/
data/*.zip
data/*.wav
data/*.mp3

# Temporary files
tmp/
temp/
*.tmp
*.bak
*.log

# OS files
.DS_Store
Thumbs.db

# Backup folders
backup_*/
*.old

# Jupyter Notebook
.ipynb_checkpoints

# Testing
.pytest_cache/
.coverage
htmlcov/

# Keep directory structure but ignore contents
!app/models/weights/.gitkeep
!data/.gitkeep
